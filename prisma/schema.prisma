generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id String @id @default(cuid())
}

model Scroll {
  id          String   @id @default(cuid())
  title       String
  description String
  mode        String
  date        String
  paperCount  Int
  exportData  String?
  createdAt   DateTime @default(now())
  papers      Paper[]
  polls       Poll[]
}

model Paper {
  id               String    @id @default(cuid())
  scrollId         String
  scroll           Scroll    @relation(fields: [scrollId], references: [id], onDelete: Cascade)
  externalId       String?
  title            String
  authors          String
  journal          String
  year             Int
  doi              String
  peerReviewed     Boolean
  synthesis        String
  credibilityScore Int
  citationCount    Int
  commentCount     Int       @default(0)
  apaCitation      String
  comments         Comment[]
  votes            Vote[]
}

model Comment {
  id           String   @id @default(cuid())
  paperId      String
  paper        Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  content      String
  author       String   @default("You")
  isGenerated  Boolean  @default(false)
  relationship String?
  createdAt    DateTime @default(now())
}

model Vote {
  id        String   @id @default(cuid())
  paperId   String
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  value     Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([paperId])
}

model Poll {
  id        String         @id @default(cuid())
  scrollId  String
  scroll    Scroll         @relation(fields: [scrollId], references: [id], onDelete: Cascade)
  type      String
  question  String
  options   String?
  responses PollResponse[]
}

model PollResponse {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  answer    String
  createdAt DateTime @default(now())

  @@unique([pollId])
}
