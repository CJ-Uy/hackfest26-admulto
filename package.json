{
  "name": "hackfest26-admulto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "prisma generate",
    "db:migrate:local": "wrangler d1 migrations apply hackfest26 --local",
    "db:migrate:remote": "wrangler d1 migrations apply hackfest26 --remote"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@prisma/adapter-d1": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "next": "16.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "19.1.5",
    "react-dom": "19.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.37",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "wrangler": "^4.75.0"
  }
}
