    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "wrangler": "^4.75.0"
  }
}
